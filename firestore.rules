rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function currentUserRole() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.is_active == true
          ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role
          : null;
    }

    function isSuperAdmin() {
      let role = currentUserRole();
      return role == "super_admin";
    }

    function isKoordinatorDivisi() {
      let role = currentUserRole();
      return role == "koordinator_divisi";
    }

    function isKoordinatorAcara() {
      let role = currentUserRole();
      return role == "koordinator_acara";
    }

    function isKoordinator() {
      let role = currentUserRole();
      return role == "super_admin" ||
        role == "koordinator_divisi" ||
        role == "koordinator_acara";
    }

    function canManageEvent(eventId) {
      return isSuperAdmin() ||
        isEventCoordinator(eventId) ||
        isEventSecretary(eventId) ||
        (
          isKoordinatorDivisi() &&
          getEventMemberRole(eventId) != "anggota_acara" &&
          getEventMemberRole(eventId) != "sekretaris_acara"
        );
    }

    function isEventMember(eventId) {
      return exists(/databases/$(database)/documents/events/$(eventId)/event_members/$(request.auth.uid));
    }

    function getEventMemberRole(eventId) {
      return isEventMember(eventId)
        ? get(/databases/$(database)/documents/events/$(eventId)/event_members/$(request.auth.uid)).data.role_in_event
        : null;
    }

    function isEventSecretary(eventId) {
      let role = getEventMemberRole(eventId);
      return role == "sekretaris_acara" || 
        role == "Sekretaris Acara" || 
        role == "sekretaris" || 
        role == "Sekretaris";
    }

    function isEventCoordinator(eventId) {
      let role = getEventMemberRole(eventId);
      return role == "koordinator_acara" ||
        role == "Koordinator Acara" ||
        role == "koordinator" ||
        role == "Koordinator" ||
        (
          exists(/databases/$(database)/documents/events/$(eventId)) &&
          get(/databases/$(database)/documents/events/$(eventId)).data.coordinator_id == request.auth.uid
        );
    }

    function canReadTaskData(data) {
      return isSuperAdmin() ||
        (
          isKoordinatorDivisi() &&
          (
            !("division_id" in data) ||
            data.division_id == "" ||
            data.division_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.division_id
          )
        ) ||
        (
          data.type == "acara" &&
          data.event_id != null &&
          data.event_id != "" &&
          (
            isEventCoordinator(data.event_id) ||
            isEventSecretary(data.event_id) ||
            isEventMember(data.event_id)
          )
        ) ||
        data.pic_id == request.auth.uid;
    }

    function canCreateTaskData(data) {
      return isSuperAdmin() ||
        (
          isKoordinatorDivisi() &&
          (data.type != "acara" || getEventMemberRole(data.event_id) != "anggota_acara") &&
          (data.type != "divisi" || data.division_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.division_id)
        ) ||
        (
          data.type == "acara" &&
          data.event_id != null &&
          data.event_id != "" &&
          (
            isEventCoordinator(data.event_id) ||
            isEventSecretary(data.event_id)
          ) &&
          data.created_by == request.auth.uid
        );
    }

    function canUpdateTaskData() {
      return isSuperAdmin() ||
        (
          isKoordinatorDivisi() &&
          (resource.data.type != "acara" || getEventMemberRole(resource.data.event_id) != "anggota_acara") &&
          (resource.data.type != "divisi" || resource.data.division_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.division_id)
        ) ||
        (
          resource.data.type == "acara" &&
          resource.data.event_id != null &&
          resource.data.event_id != "" &&
          (
            isEventCoordinator(resource.data.event_id) ||
            isEventSecretary(resource.data.event_id)
          ) &&
          request.resource.data.event_id == resource.data.event_id
        );
    }

    function canPicUpdateTaskWorkflow() {
      return resource.data.pic_id == request.auth.uid &&
        request.resource.data.pic_id == resource.data.pic_id &&
        request.resource.data.coordinator_id == resource.data.coordinator_id &&
        request.resource.data.created_by == resource.data.created_by &&
        request.resource.data.organization_id == resource.data.organization_id &&
        request.resource.data.type == resource.data.type &&
        request.resource.data.event_id == resource.data.event_id &&
        request.resource.data.division_id == resource.data.division_id &&
        (
          changedOnly(["status", "stuck_notes", "updated_at"]) ||
          changedOnly(["checklist_items", "updated_at"])
        );
    }

    function canCreateStatusLog(taskId) {
      let task = get(/databases/$(database)/documents/tasks/$(taskId)).data;
      return canReadTaskData(task) &&
        (
          isSuperAdmin() ||
          isKoordinatorDivisi() ||
          (
            isKoordinatorAcara() &&
            task.type == "acara" &&
            task.coordinator_id == request.auth.uid
          ) ||
          (
            task.type == "acara" &&
            task.event_id != null &&
            task.event_id != "" &&
            isEventSecretary(task.event_id)
          ) ||
          task.pic_id == request.auth.uid
        ) &&
        request.resource.data.task_id == taskId &&
        request.resource.data.changed_by == request.auth.uid;
    }

    function canCreateDesignReferenceData(data) {
      let role = currentUserRole();
      return (
        role == "super_admin" ||
        role == "koordinator_divisi" ||
        role == "koordinator_acara"
      ) &&
        data.organization_id == "main_org" &&
        data.created_by == request.auth.uid &&
        data.is_archived == false;
    }

    function canUpdateDesignReference() {
      let role = currentUserRole();
      return role == "super_admin" ||
        role == "koordinator_divisi" ||
        (
          role == "koordinator_acara" &&
          resource.data.created_by == request.auth.uid &&
          request.resource.data.created_by == resource.data.created_by
        );
    }

    function isSelf(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function changedOnly(allowedFields) {
      return request.resource.data.diff(resource.data).affectedKeys()
        .hasOnly(allowedFields);
    }

    function immutableUserIdentity() {
      return request.resource.data.id == resource.data.id &&
        request.resource.data.email == resource.data.email &&
        request.resource.data.organization_id == resource.data.organization_id &&
        request.resource.data.created_at == resource.data.created_at;
    }

    function selfProfileUpdateIsSafe() {
      return immutableUserIdentity() &&
        request.resource.data.role == resource.data.role &&
        request.resource.data.is_active == resource.data.is_active &&
        request.resource.data.division_id == resource.data.division_id &&
        changedOnly(["name", "whatsapp_number", "avatar_url", "updated_at"]);
    }

    function coordinatorMemberUpdateIsSafe() {
      return immutableUserIdentity() &&
        resource.data.role != "super_admin" &&
        request.resource.data.role == resource.data.role &&
        changedOnly([
          "name",
          "whatsapp_number",
          "division_id",
          "is_active",
          "updated_at"
        ]);
    }

    function isReferenceEligible(data) {
      return (
        ("reference_candidate_enabled" in data && data.reference_candidate_enabled == true) ||
        (
          !("reference_candidate_enabled" in data) &&
          data.status == "approved" &&
          (
            data.category_key == "desain_publikasi" ||
            data.category_key == "identitas_acara_dan_panitia" ||
            data.category_key == "aset_desain" ||
            data.subcategory_key == "poster" ||
            data.subcategory_key == "name_tag" ||
            data.subcategory_key == "twibbon" ||
            data.subcategory_key == "feed_ig" ||
            data.subcategory_key == "story_ig" ||
            data.subcategory_key == "banner" ||
            data.subcategory_key == "sertifikat" ||
            data.subcategory_key == "dokumentasi" ||
            data.subcategory_key == "animasi" ||
            data.subcategory_key == "merchandise" ||
            data.name.matches("(?i).*(poster|spanduk|banner|nametag|piagam|feed|story|desain).*")
          )
        )
      );
    }

    match /users/{userId} {
      allow create: if isSelf(userId) &&
        request.resource.data.role == "anggota" &&
        request.resource.data.id == request.auth.uid;

      allow read: if isSignedIn();

      allow update: if isSelf(userId) && selfProfileUpdateIsSafe();

      allow update: if isKoordinatorDivisi() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.division_id == resource.data.division_id &&
        coordinatorMemberUpdateIsSafe();

      allow update: if isSuperAdmin();
      allow delete: if false;
    }

    match /organizations/{organizationId} {
      allow read: if isSignedIn();

      allow create, update: if isSuperAdmin() &&
        organizationId == "main_org";

      allow delete: if false;
    }

    match /divisions/{divisionId} {
      allow read: if isSignedIn();

      allow create: if isSuperAdmin() &&
        request.resource.data.organization_id == "main_org";

      // super_admin bisa update semua divisi
      // koordinator_divisi hanya bisa update design_kit fields divisinya sendiri
      allow update: if isSuperAdmin() ||
        (
          isKoordinatorDivisi() &&
          get(/databases/$(database)/documents/users/$(request.auth.uid)).data.division_id == divisionId &&
          changedOnly([
            "design_kit_color_palette",
            "design_kit_visual_direction",
            "design_kit_supergraphic_notes",
            "design_kit_design_reference_links",
            "design_kit_drive_reference_links",
            "design_kit_archive_drive_links",
            "design_kit_notes_for_members",
            "updated_at"
          ])
        );

      allow delete: if false;
    }

    match /events/{eventId} {
      allow get: if isSuperAdmin() ||
        isKoordinatorDivisi() ||
        isEventMember(eventId) ||
        resource.data.coordinator_id == request.auth.uid;

      allow list: if isSuperAdmin() || isKoordinatorDivisi();
      allow list: if resource.data.coordinator_id == request.auth.uid;
      allow list: if isEventMember(eventId);

      allow create: if isSuperAdmin() ||
        isKoordinatorDivisi() ||
        (
          isKoordinatorAcara() &&
          request.resource.data.created_by == request.auth.uid &&
          request.resource.data.coordinator_id == request.auth.uid
        );

      allow update: if canManageEvent(eventId);

      allow delete: if false; // TODO: evaluasi delete acara setelah workflow task tersedia.

      match /event_members/{memberId} {
        allow read: if isSuperAdmin() ||
          isKoordinatorDivisi() ||
          isEventMember(eventId);

        allow create, update: if canManageEvent(eventId) &&
          request.resource.data.event_id == eventId &&
          request.resource.data.user_id == memberId;

        allow delete: if canManageEvent(eventId);
      }
    }

    match /tasks/{taskId} {
      allow get: if isSignedIn() && (
        canReadTaskData(resource.data) ||
        (
          isReferenceEligible(resource.data) &&
          (
            !("data_sensitivity" in resource.data) ||
            resource.data.data_sensitivity != "sensitive"
          )
        )
      );

      allow list: if isSignedIn() && (
        resource.data.pic_id == request.auth.uid ||
        isSuperAdmin() ||
        (
          isKoordinatorDivisi() &&
          (
            !("division_id" in resource.data) ||
            resource.data.division_id == "" ||
            resource.data.division_id == get(/databases/$(database)/documents/users/$(request.auth.uid)).data.division_id
          )
        ) ||
        (
          resource.data.event_id != null &&
          resource.data.event_id != "" &&
          (
            isEventCoordinator(resource.data.event_id) ||
            isEventSecretary(resource.data.event_id) ||
            isEventMember(resource.data.event_id)
          )
        ) ||
        (
          isReferenceEligible(resource.data)
        )
      );

      allow create: if isSignedIn() &&
        canCreateTaskData(request.resource.data) &&
        request.resource.data.organization_id == "main_org" &&
        request.resource.data.is_archived == false;

      allow update: if isSignedIn() &&
        (canUpdateTaskData() || canPicUpdateTaskWorkflow());

      allow delete: if false;

      match /status_logs/{logId} {
        allow read: if isSignedIn() &&
          canReadTaskData(get(/databases/$(database)/documents/tasks/$(taskId)).data);
        allow create: if isSignedIn() && canCreateStatusLog(taskId);
        allow update, delete: if false;
      }

      match /uploads/{uploadId} {
        allow read: if isSignedIn() && (
          canReadTaskData(get(/databases/$(database)/documents/tasks/$(taskId)).data) ||
          (
            isReferenceEligible(get(/databases/$(database)/documents/tasks/$(taskId)).data) &&
            (
              !("data_sensitivity" in get(/databases/$(database)/documents/tasks/$(taskId)).data) ||
              get(/databases/$(database)/documents/tasks/$(taskId)).data.data_sensitivity != "sensitive"
            )
          )
        );
        allow create, update, delete: if false; // Metadata upload ditulis server API via Admin SDK.
      }
    }

    match /design_references/{referenceId} {
      allow read: if isSignedIn() &&
        (resource.data.is_archived == false || isKoordinator());

      allow create: if isSignedIn() &&
        canCreateDesignReferenceData(request.resource.data) &&
        request.resource.data.id == referenceId;

      allow update: if isSignedIn() &&
        canUpdateDesignReference() &&
        request.resource.data.id == resource.data.id &&
        request.resource.data.organization_id == resource.data.organization_id &&
        request.resource.data.created_by == resource.data.created_by &&
        request.resource.data.created_at == resource.data.created_at;

      allow delete: if false;
    }

    match /whatsapp_logs/{logId} {
      allow read: if isKoordinator();
      allow write: if false; // Log WhatsApp ditulis server API via Admin SDK.
    }

    match /ai_logs/{logId} {
      allow read: if isKoordinator();
      allow write: if false; // Log AI ditulis server API via Admin SDK.
    }

    match /whatsapp_task_candidates/{candidateId} {
      allow read, write: if false;
    }

    match /whatsapp_task_edit_previews/{previewId} {
      allow read, write: if false;
    }

    match /{path=**}/event_members/{memberId} {
      allow read: if isSignedIn() && (
        isSuperAdmin() ||
        isKoordinatorDivisi() ||
        request.auth.uid == resource.data.user_id
      );
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
